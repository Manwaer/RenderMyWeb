@model WorkoutLog.ViewModels.WorkoutViewModel

@{
    ViewData["Title"] = "Редактировать тренировку";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">

            <h1 class="mb-4">✏️ Редактировать тренировку</h1>
            <hr />

            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                @* Скрытое поле ID *@
                <input type="hidden" asp-for="Id" />

                @* Дата *@
                <div class="form-group mb-3">
                    <label asp-for="Date" class="form-label fw-bold"></label>
                    <input asp-for="Date" class="form-control" type="date"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="Date" class="text-danger small"></span>
                </div>

                @* Тип тренировки *@
                <div class="form-group mb-3">
                    <label asp-for="Type" class="form-label fw-bold"></label>
                    <select asp-for="Type" class="form-select">
                        <option value="">-- Выберите тип --</option>
                        @foreach (var type in Model.AvailableTypes)
                        {
                            <option value="@type"
                                    selected="@(type == Model.Type ? "selected" : null)">
                                @type
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Type" class="text-danger small"></span>
                </div>

                @* Упражнение *@
                <div class="form-group mb-3">
                    <label asp-for="Exercise" class="form-label fw-bold"></label>
                    <input asp-for="Exercise" class="form-control" />
                    <span asp-validation-for="Exercise" class="text-danger small"></span>
                </div>

                @* Время начала *@
                <div class="form-group mb-3">
                    <label asp-for="StartTime" class="form-label fw-bold"></label>
                    <input asp-for="StartTime" class="form-control" type="time" />
                    <span asp-validation-for="StartTime" class="text-danger small"></span>
                </div>

                @* Продолжительность *@
                <div class="form-group mb-3">
                    <label asp-for="Duration" class="form-label fw-bold"></label>
                    <div class="input-group">
                        <input asp-for="Duration" class="form-control"
                               type="number" min="1" max="500" />
                        <span class="input-group-text">минут</span>
                    </div>
                    <span asp-validation-for="Duration" class="text-danger small"></span>
                </div>

                @* Заметки *@
                <div class="form-group mb-4">
                    <label asp-for="Notes" class="form-label fw-bold"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Notes" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        💾 Сохранить изменения
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        ↩️ Отмена
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}