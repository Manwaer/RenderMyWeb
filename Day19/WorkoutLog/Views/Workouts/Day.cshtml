@model IEnumerable<WorkoutLog.Models.Workout>

@{
    ViewData["Title"] = "Тренировки за день";
    var selectedDate = (DateTime)ViewBag.SelectedDate;
}

<div class="container mt-4">
    <h1 class="mb-3">
        📅 Тренировки за @selectedDate.ToString("dd MMMM yyyy",
                    new System.Globalization.CultureInfo("ru-RU"))
    </h1>

    <div class="mb-3 d-flex gap-2">
        <a asp-action="Index" class="btn btn-secondary">
            ← Все тренировки
        </a>
        <a asp-action="Create" class="btn btn-success">
            ➕ Добавить
        </a>
    </div>

    @if (Model.Any())
    {
        @* Сводка за день *@
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-white bg-primary">
                    <div class="card-body text-center">
                        <h5 class="card-title">Тренировок</h5>
                        <h2>@Model.Count()</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success">
                    <div class="card-body text-center">
                        <h5 class="card-title">Общее время</h5>
                        <h2>@Model.Sum(w => w.Duration) мин</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card bg-light">
                    <div class="card-body">
                        <h6 class="card-title">По типам:</h6>
                        @foreach (var group in Model.GroupBy(w => w.Type))
                        {
                            <span class="badge bg-secondary me-1">
                                @group.Key: @group.Sum(w => w.Duration) мин
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Тип</th>
                    <th>Упражнение</th>
                    <th>Время</th>
                    <th>Продолжительность</th>
                    <th>Заметки</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="badge bg-primary">@item.Type</span></td>
                        <td>@(item.Exercise ?? "—")</td>
                        <td>
                            @(item.StartTime.HasValue
                                ? item.StartTime.Value.ToString(@"hh\:mm")
                                : "—")
                        </td>
                        <td>@item.Duration мин</td>
                        <td>
                            <small class="text-muted">
                                @(item.Notes ?? "—")
                            </small>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning">✏️</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger">🗑️</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-warning">
            На эту дату тренировок не найдено.
            <a asp-action="Create" class="alert-link">Добавить тренировку</a>
        </div>
    }
</div>